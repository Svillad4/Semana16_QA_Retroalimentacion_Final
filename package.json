{
  "name": "semana16-qa-retroalimentacion-final",
  "version": "1.0.0",
  "description": "Actividad Semana 16: QA, retroalimentacion entre pares y plan de mejora del proyecto web final.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "db": "json-server --watch db.json --port 3001",
