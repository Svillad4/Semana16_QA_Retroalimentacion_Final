    "evidencias": "node scripts/crear-evidencias.cjs"
  },
  "dependencies": {
    "@vitejs/plugin-legacy": "latest",
    "bootstrap": "latest",
    "bootstrap-icons": "latest",
    "chart.js": "latest",
